# TernakOS — Environment Variables
# Copy this file to .env and fill in the values.

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI — Primary: MAIA Router (maiarouter.ai)
VITE_MAIA_API_KEY=your_maia_api_key_here
# Model yang dipakai via MAIA — harus pakai prefix xai/
VITE_AI_MODEL=xai/grok-4-1-fast-reasoning-latest

# AI — Fallback: GLM ZhipuAI (opsional, backup jika MAIA down)
VITE_GLM_API_KEY=your_glm_api_key_here

VITE_WHATSAPP_NUMBER=your_whatsapp_number_here
